enum DiscordScheduleType {
  ONCE
  RECURRING
}

model DiscordScheduledMessage {
  id             String              @id @default(uuid())
  guildId        String
  channelId      String
  name           String
  type           DiscordScheduleType
  cronExpression String?
  scheduledAt    DateTime?
  templateId     String?
  content        String?
  embedJson      String?
  enabled        Boolean             @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  bullMqJobId    String?
  repeatJobKey   String?
  createdBy      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([guildId, name])
  @@index([guildId])
  @@index([enabled])
}
