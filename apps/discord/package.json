{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "A Discord bot with various features for a community server.",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "bun src/app.ts",
    "dev": "bun --watch src/app.ts",
    "lint": "eslint . --ext .ts,.js --fix",
    "lint:check": "eslint . --ext .ts,.js",
    "format": "prettier-eslint --write $PWD/'**/*.{js,json}'",
    "test": "cross-env NODE_ENV=test mocha tests --exit",
    "check-types": "tsc --noEmit"
  },
  "author": "MrDemonWolf, Inc",
  "license": "MIT",
  "dependencies": {
    "@community-bot/db": "workspace:*",
    "@community-bot/env": "workspace:*",
    "@community-bot/events": "workspace:*",
    "@community-bot/logging": "workspace:*",
    "@community-bot/server": "workspace:*",
    "@discordjs/core": "^2.4.0",
    "@discordjs/rest": "^2.6.0",
    "bullmq": "^5.66.2",
    "consola": "^3.4.2",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.9.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "ioredis": "^5.8.2",
    "node-cron": "^4.2.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "prettier-eslint-cli": "^8.0.1",
    "typescript": "^5.9.3"
  }
}
